# ============================================================
# PC Builder Agent - environment configuration
# Copy this file to `.env` and edit values as needed.
# ============================================================

# ---- LLM provider ----
# Options:
#   github      -> GitHub Models, FREE for personal use, PwC-compatible   [DEFAULT]
#                  PAT: https://github.com/settings/tokens
#   cerebras    -> hosted, FREE, very fast Llama 3.3 70B
#                  https://cloud.cerebras.ai (Google sign-in, no card)
#   huggingface -> hosted, FREE, open-source models via HF Inference API
#                  https://huggingface.co/settings/tokens
#   groq        -> hosted, FREE, very fast Llama / Qwen (may be blocked on some corp networks)
#                  https://console.groq.com/keys
#   ollama      -> fully local, no API key (requires Ollama installed)
#   openai      -> paid, optional
#   anthropic   -> paid, optional
LLM_PROVIDER=github

# ---- GitHub Models (default - PwC-compatible, free for personal use) ----
# Create a free Personal Access Token at https://github.com/settings/tokens
# Default model is Llama 3.3 70B Instruct (open weights).
GITHUB_TOKEN=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODEL=meta/llama-3.3-70b-instruct
GITHUB_FALLBACK_MODEL=meta/meta-llama-3.1-8b-instruct

# ---- Cerebras (alternative - free, fast, OpenAI-compatible) ----
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama-3.3-70b
CEREBRAS_FALLBACK_MODEL=llama3.1-8b

# ---- HuggingFace (alternative hosted free provider) ----
HF_TOKEN=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_FALLBACK_MODEL=HuggingFaceH4/zephyr-7b-beta

# ---- Groq (alternative hosted free provider) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# ---- Ollama (offline / fully-local option) ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_FALLBACK_MODEL=phi3:mini

# ---- LLM behavior ----
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_S=120
LLM_MAX_RETRIES=3
MAX_TOKENS_PER_TURN=8000
MAX_AGENT_STEPS=25

# ---- Data download ----
# Set to false if you are on a corporate VPN that breaks SSL to GitHub
# (also disables cert verification for LLM calls, needed on PwC / similar networks)
DATA_SSL_VERIFY=true

# ---- Paths ----
DATA_DIR=./data/csv
TRACE_DIR=./traces
MEMORY_DB_PATH=./data/memory.sqlite

# ---- Optional: alternative providers ----
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
